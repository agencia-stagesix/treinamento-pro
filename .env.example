# ─────────────────────────────────────────────────────────────────────────────
# STCA — App Treinamento Pro
# Copy this file to .env inside apps/api/ and fill in the values.
# For the web app copy to apps/web/.env.local (only NEXT_PUBLIC_* vars needed).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase project ─────────────────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY  # "service_role" secret key — NEVER expose publicly
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY  # "anon" public key

# PostgreSQL connection string (direct, used by migrations)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# JWT secret — Supabase dashboard > Settings > API > JWT Secret
JWT_SECRET=YOUR_SUPABASE_JWT_SECRET

# ── API server ───────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=https://YOUR_WEB_APP.vercel.app  # URL of the web frontend (not the API)

# ── Storage ──────────────────────────────────────────────────────────────────
# Supabase Storage bucket name (create it in the dashboard)
STORAGE_BUCKET_NAME=treinamento-pro

# ── Web / Next.js (.env.local) ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
